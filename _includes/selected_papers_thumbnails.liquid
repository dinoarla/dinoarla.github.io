<div class="row mt-3 mb-4 g-2">
  {% for pub in site.data.selected_pubs %}
    <div class="col-4 col-sm-4">
      <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer" title="{{ pub.title }}">
        <img
          src="{{ pub.preview | prepend: '/assets/img/publication_preview/' | relative_url }}"
          alt="{{ pub.title }}"
          class="img-fluid rounded z-depth-1"
          loading="lazy"
          style="width: 100%; height: 90px; object-fit: cover;"
        />
      </a>
    </div>
  {% endfor %}
</div>
