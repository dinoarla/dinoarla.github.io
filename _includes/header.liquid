<header>
  {%- assign is_id = false -%}
  {%- if page.lang == 'id' -%}{%- assign is_id = true -%}{%- endif -%}
  {%- if is_id -%}
    {%- assign en_url = page.url | remove_first: '/id' -%}
    {%- if en_url == '' -%}{%- assign en_url = '/' -%}{%- endif -%}
    {%- assign id_url = page.url -%}
  {%- else -%}
    {%- assign en_url = page.url -%}
    {%- if page.lang == 'en' -%}
      {%- assign id_url = '/id/' -%}
    {%- else -%}
      {%- assign id_url = '/id' | append: page.url -%}
    {%- endif -%}
  {%- endif -%}

  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      {% if page.permalink != '/' and page.permalink != '/id/' %}
        <a class="navbar-brand title font-weight-lighter" href="{% if is_id %}/id/{% else %}{{ site.baseurl }}/{% endif %}">
            {% if site.first_name %}
              <span class="font-weight-bold">
                {{- site.first_name -}}
              </span>
            {% endif %}
            {% if site.middle_name %}
              {{- site.middle_name -}}
            {% endif %}
            {% if site.last_name %}
              {{- site.last_name -}}
            {% endif %}
        </a>
      {% elsif site.enable_navbar_social %}
        <!-- Social Icons -->
        <div class="navbar-brand social">{% include social.liquid %}</div>
      {% endif %}
      <!-- Navbar Toggle — opens fullscreen overlay on mobile -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        onclick="openMobileNav()"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">

          {% if is_id %}
            <!-- Indonesian navigation -->
            <li class="nav-item {% if page.url == '/id/' %}active{% endif %}">
              <a class="nav-link" href="/id/">Tentang</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/publications/">Publikasi</a>
            </li>
            <li class="nav-item {% if page.url contains '/id/projects/' %}active{% endif %}">
              <a class="nav-link" href="/id/projects/">Proyek</a>
            </li>
            <li class="nav-item {% if page.url contains '/id/blog/' %}active{% endif %}">
              <a class="nav-link" href="/id/blog/">Catatan</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/assets/pdf/DinoArla_Vitae_0526.pdf">CV</a>
            </li>
            <li class="nav-item {% if page.url contains '/id/calendar/' %}active{% endif %}">
              <a class="nav-link" href="/id/calendar/">Kalender</a>
            </li>

          {% else %}
            <!-- English navigation -->
            {% for p in site.pages %}
              {% if p.permalink == '/' %} {% assign about_title = p.title %} {% endif %}
            {% endfor %}

            <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
              <a class="nav-link" href="{{ '/' | relative_url }}">
                {{- about_title }}
                {% if page.permalink == '/' %}
                  <span class="sr-only">(current)</span>
                {% endif %}
              </a>
            </li>

            {% assign sorted_pages = site.pages | sort: 'nav_order' %}
            {% for p in sorted_pages %}
              {% if p.nav and p.autogen == null %}
                {% if p.dropdown %}
                  {% assign has_active_child = false %}
                  {% for child in p.children %}
                    {% if page.title == child.title %}
                      {% assign has_active_child = true %}
                    {% endif %}
                  {% endfor %}
                  <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                    <a
                      class="nav-link dropdown-toggle"
                      href="#"
                      id="navbarDropdown"
                      role="button"
                      data-toggle="dropdown"
                      aria-haspopup="true"
                      aria-expanded="false"
                    >
                      {{- p.title }}
                      {% if page.title == p.title or has_active_child %}
                        <span class="sr-only">(current)</span>
                      {% endif %}
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                      {% for child in p.children %}
                        {% if child.title == 'divider' %}
                          <div class="dropdown-divider"></div>
                        {% else %}
                          <a
                            class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                            href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                          >
                            {{- child.title -}}
                          </a>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </li>
                {% else %}
                  {% assign parent_link = p.permalink | remove: 'index.html' %}
                  <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                    {%- if p.permalink contains '://' -%}
                      {%- assign url = p.permalink -%}
                    {%- elsif p.permalink contains '/blog/' -%}
                      {%- assign url = '/blog/' -%}
                    {%- else -%}
                      {%- assign url = p.url -%}
                    {%- endif %}
                    <a class="nav-link" href="{{ url | relative_url }}">
                      {{- p.title }}
                      {% if page.url contains p.url %}
                        <span class="sr-only">(current)</span>
                      {% endif %}
                    </a>
                  </li>
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}

          <!-- Language Switcher -->
          <li class="nav-item lang-switcher">
            <a class="lang-btn {% unless is_id %}lang-btn-active{% endunless %}" href="{{ en_url }}">EN</a>
            <span class="lang-divider">·</span>
            <a class="lang-btn {% if is_id %}lang-btn-active{% endif %}" href="{{ id_url }}">ID</a>
          </li>

          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search (ctrl k)" onclick="openSearchModal()">
                <span class="nav-link"><i class="ti ti-search"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Toggle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="ti ti-sun-moon" id="light-toggle-system"></i>
                <i class="ti ti-moon-filled" id="light-toggle-dark"></i>
                <i class="ti ti-sun-filled" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>

  <!-- Full-screen mobile nav overlay -->
  <div id="mobile-nav-overlay" class="mobile-nav-overlay" aria-hidden="true" role="dialog">
    <div class="mobile-nav-header">
      <a class="mobile-nav-brand" href="{% if is_id %}/id/{% else %}{{ '/' | relative_url }}{% endif %}" onclick="closeMobileNav()">
        <span class="mobile-nav-brand-first">{{ site.first_name }}</span>&nbsp;{{ site.last_name }}
      </a>
      <button class="mobile-nav-close" onclick="closeMobileNav()" aria-label="Close menu">
        <i class="ti ti-x"></i>
      </button>
    </div>

    <nav class="mobile-nav-links">
      {% if is_id %}
        <!-- Indonesian mobile nav -->
        <a href="/id/" class="mobile-nav-link {% if page.url == '/id/' %}active{% endif %}" onclick="closeMobileNav()">Tentang</a>
        <a href="/publications/" class="mobile-nav-link" onclick="closeMobileNav()">Publikasi</a>
        <a href="/id/projects/" class="mobile-nav-link {% if page.url contains '/id/projects/' %}active{% endif %}" onclick="closeMobileNav()">Proyek</a>
        <a href="/id/blog/" class="mobile-nav-link {% if page.url contains '/id/blog/' %}active{% endif %}" onclick="closeMobileNav()">Catatan</a>
        <a href="/assets/pdf/DinoArla_Vitae_0526.pdf" class="mobile-nav-link">CV</a>
        <a href="/id/calendar/" class="mobile-nav-link {% if page.url contains '/id/calendar/' %}active{% endif %}" onclick="closeMobileNav()">Kalender</a>
      {% else %}
        <!-- English mobile nav -->
        {% assign sorted_pages = site.pages | sort: 'nav_order' %}
        <a href="{{ '/' | relative_url }}"
           class="mobile-nav-link {% if page.permalink == '/' %}active{% endif %}"
           onclick="closeMobileNav()">
          {{- about_title -}}
        </a>
        {% for p in sorted_pages %}
          {% if p.nav and p.autogen == null %}
            {% unless p.dropdown %}
              {%- if p.permalink contains '://' -%}
                {%- assign murl = p.permalink -%}
              {%- elsif p.permalink contains '/blog/' -%}
                {%- assign murl = '/blog/' -%}
              {%- else -%}
                {%- assign murl = p.url -%}
              {%- endif %}
              {% assign parent_link = p.permalink | remove: 'index.html' %}
              <a href="{{ murl | relative_url }}"
                 class="mobile-nav-link {% if page.url contains parent_link %}active{% endif %}"
                 onclick="closeMobileNav()">
                {{- p.title -}}
              </a>
            {% endunless %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </nav>

    <div class="mobile-nav-actions">
      <!-- Language switcher in mobile overlay -->
      <div class="mobile-lang-switcher">
        <a class="mobile-lang-btn {% unless is_id %}mobile-lang-active{% endunless %}" href="{{ en_url }}" onclick="closeMobileNav()">EN</a>
        <span class="mobile-lang-divider">·</span>
        <a class="mobile-lang-btn {% if is_id %}mobile-lang-active{% endif %}" href="{{ id_url }}" onclick="closeMobileNav()">ID</a>
      </div>
      {% if site.search_enabled %}
        <button class="mobile-nav-action-btn" onclick="closeMobileNav(); setTimeout(openSearchModal, 300);" aria-label="Search">
          <i class="ti ti-search"></i>
        </button>
      {% endif %}
      {% if site.enable_darkmode %}
        <button class="mobile-nav-action-btn" onclick="document.getElementById('light-toggle').click()" aria-label="Toggle theme">
          <i class="ti ti-sun-moon"></i>
        </button>
      {% endif %}
    </div>
  </div>

  <script>
    function openMobileNav() {
      var overlay = document.getElementById('mobile-nav-overlay');
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileNav() {
      var overlay = document.getElementById('mobile-nav-overlay');
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeMobileNav();
    });
  </script>

  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
