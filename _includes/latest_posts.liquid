<div class="latest-notes-list">
  {% if site.latest_posts != blank %}
    {% assign all_posts = site.posts %}
    {% if site.latest_posts.limit %}
      {% assign posts_limit = site.latest_posts.limit %}
    {% else %}
      {% assign posts_limit = all_posts.size %}
    {% endif %}
    {% assign shown_posts = all_posts | limit: posts_limit %}

    {% assign years = "" | split: "|" %}
    {% for post in shown_posts %}
      {% assign yr = post.date | date: "%Y" %}
      {% unless years contains yr %}
        {% assign years = years | push: yr %}
      {% endunless %}
    {% endfor %}

    {% for year in years %}
      <div class="notes-year-group">
        <div class="notes-year-header">
          <span class="notes-year-label">{{ year }}</span>
        </div>

        {% assign yr_count = 0 %}
        {% for post in shown_posts %}
          {% assign post_year = post.date | date: "%Y" %}
          {% if post_year == year %}
            {% assign yr_count = yr_count | plus: 1 %}
            <div class="notes-row{% if yr_count > 3 %} notes-row-hidden{% endif %}">
              <span class="notes-date">{{ post.date | date: '%b %d' }}</span>
              {% if post.redirect == blank %}
                <a class="notes-title" href="{{ post.url | relative_url }}">{{ post.title }}</a>
              {% elsif post.redirect contains '://' %}
                <a class="notes-title" href="{{ post.redirect }}" target="_blank">{{ post.title }}</a>
              {% else %}
                <a class="notes-title" href="{{ post.redirect | relative_url }}">{{ post.title }}</a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}

        {% assign extra = yr_count | minus: 3 %}
        {% if extra > 0 %}
          <button class="notes-show-more" onclick="notesShowMore(this)">
            Show {{ extra }} more from {{ year }}
          </button>
        {% endif %}
      </div>
    {% endfor %}

    <div class="notes-footer">
      <a href="{{ '/blog/' | relative_url }}" class="notes-view-all">View all notes &rarr;</a>
    </div>
  {% else %}
    <p>No posts so far...</p>
  {% endif %}
</div>

<script>
  function notesShowMore(btn) {
    var group = btn.closest('.notes-year-group');
    group.querySelectorAll('.notes-row-hidden').forEach(function(row) {
      row.classList.remove('notes-row-hidden');
    });
    btn.style.display = 'none';
  }
</script>
